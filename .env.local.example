# ─────────────────────────────────────────────────────────────
# ManageMate 環境変数ひな形
# 使い方: このファイルを .env.local にコピーして値を埋める。
#   cp .env.local.example .env.local
# .env.local は .gitignore 済み。秘密値は絶対にコミットしない。
# フェーズ1（この骨格）では未使用。フェーズ2/3で有効化する。
# ─────────────────────────────────────────────────────────────

# --- Supabase（フロントに出てよい公開値。フェーズ2） ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- サーバー専用（絶対にフロントに出さない） ---
# サーバー側処理用（フェーズ2）
SUPABASE_SERVICE_ROLE_KEY=
# AI呼び出し。app/api/ai/route.ts でのみ使用（サーバー専用。フロントに出さない）
ANTHROPIC_API_KEY=
# 使用モデル（任意。未指定なら claude-sonnet-5）。低コストにしたい場合は Haiku 系を指定
ANTHROPIC_MODEL=

# --- Web Push 通知（フェーズ4。docs/PHASE4_PUSH.md）---
# VAPID 鍵ペア。`npx web-push generate-vapid-keys` で生成できる。
# 公開鍵はフロントに出てよい（購読の applicationServerKey に使う）。
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
# 秘密鍵はサーバー専用。絶対にフロントに出さない。
# 同じ値を Supabase の Function Secrets（VAPID_PRIVATE_KEY）にも設定する。
VAPID_PRIVATE_KEY=
# 連絡先（Push サービスへの識別子）。mailto: か https: のURL。
VAPID_SUBJECT=mailto:admin@example.com

# --- Google連携（フェーズ3。Vercelの環境変数に登録。docs/PHASE3_GOOGLE_CALENDAR.md）---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Zoom連携（会議の自動作成。Zoom Marketplace の General/User-managed アプリ）---
# サーバー専用。フロントに出さない。Vercel の Environment Variables にも登録する。
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=
# OAuthリダイレクト先。Zoom側の許可リストと完全一致させる（本番ドメイン）。
# 未指定ならリクエストのoriginから /api/zoom/callback を生成。
ZOOM_REDIRECT_URI=https://managemate-olive.vercel.app/api/zoom/callback
